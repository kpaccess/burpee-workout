# Copy this file to .env.test.local and fill in any blanks before running QA tests.
# .env.test.local is gitignored — never commit the real file.

# ── Firebase emulator ──────────────────────────────────────────────────────
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=http://127.0.0.1:9099
NEXT_PUBLIC_FIREBASE_PROJECT_ID=burpee-workout

# Disable real service account — emulator accepts any credential
FIREBASE_SERVICE_ACCOUNT_KEY=

# ── Test credentials (auto-created in the emulator by global-setup.ts) ────
TEST_USER_EMAIL=qa-user@test.com
TEST_USER_PASSWORD=QaTestPass123!
TEST_ADMIN_EMAIL=qa-admin@test.com
TEST_ADMIN_PASSWORD=QaAdminPass123!

# Must match TEST_ADMIN_EMAIL so admin tests pass
NEXT_PUBLIC_ADMIN_EMAILS=qa-admin@test.com
ALLOWLISTED_EMAILS=qa-user@test.com,qa-admin@test.com

# ── Stripe: inherited from .env.local (test-mode keys, no real charges) ───
# Override here only if you need a separate Stripe test account for QA.

# ── Email: disable real sends during tests ─────────────────────────────────
RESEND_API_KEY=
